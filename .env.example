# =============================================================================
# MCRcore Growth Engine - Environment Configuration
# Copy this file to .env and fill in all PLACEHOLDER values
# =============================================================================

# --- Database ---
# SQLite for dev, PostgreSQL for production
DATABASE_URL=sqlite:///mcr_growth_engine.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO_SQL=false

# --- LLM / OpenAI-Compatible API ---
LLM_API_KEY=PLACEHOLDER_your-openai-api-key
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# --- Microsoft Teams Webhooks ---
# Main webhook for general notifications
MS_TEAMS_WEBHOOK_URL=PLACEHOLDER_https://outlook.office.com/webhook/your-main-webhook-url
# Channel-specific webhooks (set to same URL if using single channel)
TEAMS_WEBHOOK_URL=PLACEHOLDER_https://outlook.office.com/webhook/your-main-webhook-url
TEAMS_WEBHOOK_DEALS=PLACEHOLDER_https://outlook.office.com/webhook/your-deals-channel-webhook
TEAMS_WEBHOOK_ALERTS=PLACEHOLDER_https://outlook.office.com/webhook/your-alerts-channel-webhook
TEAMS_WEBHOOK_DIGEST=PLACEHOLDER_https://outlook.office.com/webhook/your-digest-channel-webhook
TEAMS_NOTIFICATIONS_ENABLED=true

# --- SMTP Email Sending ---
SMTP_HOST=PLACEHOLDER_smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=PLACEHOLDER_your-email@mcrcore.com
SMTP_USER=PLACEHOLDER_your-email@mcrcore.com
SMTP_PASSWORD=PLACEHOLDER_your-smtp-password
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=PLACEHOLDER_growth@mcrcore.com
SMTP_FROM=PLACEHOLDER_growth@mcrcore.com
EMAIL_FROM_NAME=MCRcore Business Intelligence
SMTP_RATE_LIMIT_PER_MINUTE=30

# --- IMAP Email Receiving (for reply processing) ---
IMAP_HOST=PLACEHOLDER_imap.office365.com
IMAP_PORT=993
IMAP_USERNAME=PLACEHOLDER_your-email@mcrcore.com
IMAP_PASSWORD=PLACEHOLDER_your-imap-password
IMAP_USE_SSL=true
IMAP_FOLDER=INBOX

# --- Escalation ---
ESCALATION_EMAIL=PLACEHOLDER_sales@mcrcore.com

# --- Lead Source API Keys ---
# LinkedIn Sales Navigator
LINKEDIN_SALES_NAV_KEY=PLACEHOLDER_your-linkedin-key
LINKEDIN_SALES_NAV_SECRET=PLACEHOLDER_your-linkedin-secret

# Apollo.io
APOLLO_API_KEY=PLACEHOLDER_your-apollo-api-key

# ZoomInfo
ZOOMINFO_API_KEY=PLACEHOLDER_your-zoominfo-api-key
ZOOMINFO_CLIENT_ID=PLACEHOLDER_your-zoominfo-client-id

# Email verification service (ZeroBounce, NeverBounce, etc.)
EMAIL_VERIFY_API_KEY=PLACEHOLDER_your-email-verify-key

# CRM integration (HubSpot, Salesforce, etc.)
CRM_API_KEY=PLACEHOLDER_your-crm-api-key

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
